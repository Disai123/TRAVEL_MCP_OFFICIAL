# ============================================================
# Smart MCP Trip Planner — .gitignore
# Covers: Python/FastAPI backend + React/Vite frontend
# ============================================================

# ──────────────────────────────────────────
# ENVIRONMENT & SECRETS (NEVER commit these)
# ──────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local
!.env.example        # Keep the example template

# ──────────────────────────────────────────
# PYTHON / BACKEND
# ──────────────────────────────────────────
# Virtual environments
venv/
.venv/
env/
ENV/

# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
*.xml

# MyPy / type checkers
.mypy_cache/
.dmypy.json

# Jupyter notebooks checkpoints
.ipynb_checkpoints/

# ──────────────────────────────────────────
# NODE / FRONTEND
# ──────────────────────────────────────────
node_modules/
frontend/node_modules/

# Vite build output
frontend/dist/
frontend/.vite/

# npm / yarn lockfiles (optional — keep if you want reproducible installs)
# package-lock.json
# yarn.lock

# ──────────────────────────────────────────
# DATA FILES (large, binary, or sensitive)
# ──────────────────────────────────────────
# Hotel dataset (37 MB CSV — too large for GitHub)
backend/travel_sample.csv
*.sqlite
*.db

# ──────────────────────────────────────────
# OS & EDITOR FILES
# ──────────────────────────────────────────
# Windows
Thumbs.db
desktop.ini
ehthumbs.db

# macOS
.DS_Store
.AppleDouble
.LSOverride

# VS Code
.vscode/
*.code-workspace

# JetBrains IDEs
.idea/
*.iml

# ──────────────────────────────────────────
# LOGS & TEMP
# ──────────────────────────────────────────
*.log
logs/
tmp/
temp/
