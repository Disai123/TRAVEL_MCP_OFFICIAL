# Google Gemini API Key (Required for Agent)
# Get yours free at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Aviation Stack API Key (Required for Flights)
AVIATIONSTACK_API_KEY=your_aviationstack_key_here

# Travel Server DB (Local)
# In production content, ensure this file exists or update to a Cloud SQL URL
TRAVEL_DB_PATH=travel.db
